# Copy this to .env and fill in your values
# NEVER commit .env to git

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API — for DALL-E 3 image generation (platform.openai.com)
OPENAI_API_KEY=sk-...

# Vercel — get from vercel.com/account/tokens
VERCEL_TOKEN=...

# Cloudflare — get from dash.cloudflare.com/profile/api-tokens
# Create a token with "Zone:DNS:Edit" permissions
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ZONE_ID=...  # Found in your domain's overview page on Cloudflare

# Shopify — for e-commerce site generation (optional)
# Create a private app in your Shopify admin
SHOPIFY_ACCESS_TOKEN=...
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com

# WordPress — for blog site generation (optional)
WORDPRESS_URL=https://yourblog.com
WORDPRESS_USER=admin
WORDPRESS_PASSWORD=your-app-password
